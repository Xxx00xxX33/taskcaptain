# Network binding
PRODUCTS_UI_HOST=127.0.0.1
PRODUCTS_UI_PORT=8765
PRODUCTS_UI_DEFAULT_LANG=zh

# Default OpenAI-compatible endpoint used in the UI form defaults
PRODUCTS_UI_DEFAULT_OPENAI_BASE_URL=https://api.loveatri.su/v1
PRODUCTS_UI_DEFAULT_OPENAI_API_KEY=sk-pvVnxLEwR1SKD5Q9U5pwf7z2reGTieDj98aP5izGv3NTYywY
PRODUCTS_UI_DEFAULT_CODEX_BASE_URL=https://api.loveatri.su/v1
PRODUCTS_UI_DEFAULT_CODEX_API_KEY=sk-pvVnxLEwR1SKD5Q9U5pwf7z2reGTieDj98aP5izGv3NTYywY

# Optional default writable workspace offered to new products
PRODUCTS_UI_DEFAULT_PRODUCT_FOLDER=./workspace

# Optional default proxy for task runtime / self-test / Codex subprocesses
# Leave empty if not needed; each task can override this in the UI.
PRODUCTS_UI_PROXY=
PRODUCTS_UI_NO_PROXY=127.0.0.1,localhost,::1

# Optional explicit acpx binary path
# ACPX_BIN=/absolute/path/to/acpx

# Optional explicit Rust fastview helper path
# If unset, TaskCaptain auto-detects ./rust/taskcaptain-fastview/target/release/taskcaptain-fastview
# TASKCAPTAIN_FASTVIEW_BIN=/absolute/path/to/taskcaptain-fastview
